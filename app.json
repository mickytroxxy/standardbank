{
  "expo": {
    "name": "Standard/Stanic Bank",
    "slug": "standardbank",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "standardbank",
    "userInterfaceStyle": "automatic",
    "ios": {
      "infoPlist": {
        "UIBackgroundModes": ["location", "remote-notification"]
      },
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon.png",
        "backgroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json",
      "package": "com.standardbank.stanic.clone",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#003ccd",
          "android": {
            "image": "./assets/images/logo.png",
            "imageWidth": 85
          }
        }
      ],
      "@react-native-vector-icons/material-design-icons",
      "@react-native-vector-icons/ionicons",
      "@react-native-vector-icons/feather",
      "@react-native-vector-icons/material-icons",
      "expo-sharing",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#003ccd",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Standard Bank requires your location to verify where transactions are made.",
          "locationWhenInUsePermission": "Standard Bank requires your location to verify where transactions are made.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1b07eb29-9105-4c85-baab-b02d9307d9dd"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "empiredigitalsmain",
    "updates": {
      "url": "https://u.expo.dev/1b07eb29-9105-4c85-baab-b02d9307d9dd"
    }
  }
}
